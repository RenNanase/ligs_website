# Database — MySQL connection string
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME"

# NextAuth — base URL of the application
NEXTAUTH_URL="http://localhost:3000"

# NextAuth — random secret for JWT signing (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"

# Feedback form — Gmail SMTP
FEEDBACK_ADMIN_EMAIL="admin@example.com"
SMTP_USER="your-gmail@gmail.com"
SMTP_APP_PASSWORD="your-16-char-app-password"

# Optional: send confirmation email to user after feedback submission
FEEDBACK_SEND_CONFIRMATION="false"

# Optional: Google reCAPTCHA v3 secret key (prevents spam; leave empty to disable)
# RECAPTCHA_SECRET_KEY=""

# Admin credentials (if used elsewhere)
ADMIN_EMAIL="your-admin@gmail.com"
ADMIN_APP_PASSWORD="your-app-password"

# Next.js Server Actions — stable encryption key for self-hosted (reduces "Failed to find Server Action" errors)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Then add the output below (without the #):
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="paste-generated-key-here"